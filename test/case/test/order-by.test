ORDER BY TESTS

CREATE TABLE t1 (id INT, name CHAR(20), score FLOAT);
INSERT INTO t1 VALUES (1, 'alice', 85.5);
INSERT INTO t1 VALUES (2, 'bob', 92.0);
INSERT INTO t1 VALUES (3, 'carol', 78.5);
INSERT INTO t1 VALUES (4, 'dave', 92.0);

ORDER BY SCORE
SELECT * FROM t1 ORDER BY score;
ORDER BY NAME
SELECT * FROM t1 ORDER BY name;
MULTI-COLUMN ORDER BY
SELECT id, score FROM t1 ORDER BY score, id;
AS ALIAS HEADER
SELECT id AS i, name AS n FROM t1;
AS ALIAS WITH ORDER BY
SELECT id AS i, score AS s FROM t1 ORDER BY s;
ORDER BY ALIAS
SELECT name AS n, score AS s FROM t1 ORDER BY n, s;

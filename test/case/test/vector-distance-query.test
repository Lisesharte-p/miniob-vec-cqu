-- echo vector distance query and sort

create table vec_dist_query(id int, embedding vector(4));
insert into vec_dist_query values(1, string_to_vector('[1,2,3,4]'));
insert into vec_dist_query values(2, string_to_vector('[1.1,2.1,3.1,4.1]'));
insert into vec_dist_query values(3, string_to_vector('[10,20,30,40]'));
insert into vec_dist_query values(4, string_to_vector('[-1,-2,-3,-4]'));
insert into vec_dist_query values(5, string_to_vector('[0,0,0,0]'));

-- echo distance with as alias
select id, DISTANCE(embedding, string_to_vector('[1,2,3,4]'), 'EUCLIDEAN') as dis from vec_dist_query order by id;

-- echo order by distance alias ascending
select id, DISTANCE(embedding, string_to_vector('[1,2,3,4]'), 'EUCLIDEAN') as dis from vec_dist_query order by dis;

-- echo order by distance direct no alias
select id, DISTANCE(embedding, string_to_vector('[1,2,3,4]'), 'EUCLIDEAN') as dis from vec_dist_query order by DISTANCE(embedding, string_to_vector('[1,2,3,4]'), 'EUCLIDEAN');

-- echo order by distance limit 2 nearest
select id, DISTANCE(embedding, string_to_vector('[1,2,3,4]'), 'EUCLIDEAN') as dis from vec_dist_query order by dis limit 2;

-- echo order by distance limit 3
select id, DISTANCE(embedding, string_to_vector('[1,2,3,4]'), 'EUCLIDEAN') as dis from vec_dist_query order by dis limit 3;

-- echo order by distance limit 1
select id, DISTANCE(embedding, string_to_vector('[1,2,3,4]'), 'EUCLIDEAN') as dis from vec_dist_query order by dis limit 1;

-- echo order by distance limit 10 exceeds rows
select id, DISTANCE(embedding, string_to_vector('[1,2,3,4]'), 'EUCLIDEAN') as dis from vec_dist_query order by dis limit 10;

-- echo order by distance without limit full sort
select id, DISTANCE(embedding, string_to_vector('[1,2,3,4]'), 'EUCLIDEAN') as dis from vec_dist_query order by dis;

-- echo where filter plus order by plus limit
select id, DISTANCE(embedding, string_to_vector('[1,2,3,4]'), 'EUCLIDEAN') as dis from vec_dist_query where id >= 2 order by dis limit 3;

-- echo where filter plus order by no limit
select id, DISTANCE(embedding, string_to_vector('[1,2,3,4]'), 'EUCLIDEAN') as dis from vec_dist_query where id < 3 order by dis;

-- echo order by distance with dot product
select id, DISTANCE(embedding, string_to_vector('[1,2,3,4]'), 'DOT') as dot_val from vec_dist_query order by dot_val;

-- echo order by distance with dot limit 2
select id, DISTANCE(embedding, string_to_vector('[1,2,3,4]'), 'DOT') as dot_val from vec_dist_query order by dot_val limit 2;

-- echo order by distance cosine descending
select id, DISTANCE(embedding, string_to_vector('[0,1,0,0]'), 'cosine') as cos_val from vec_dist_query order by cos_val;

-- echo multiple distances in select with order by one
select id, DISTANCE(embedding, string_to_vector('[1,2,3,4]'), 'EUCLIDEAN') as euclid, DISTANCE(embedding, string_to_vector('[1,2,3,4]'), 'DOT') as dot_val from vec_dist_query order by euclid limit 3;

-- echo order by id with limit
select id, embedding from vec_dist_query order by id limit 3;
